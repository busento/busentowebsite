---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';

import heroImage from '../assets/wine-glass.jpg';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<Layout
  title="Kontakt & Reservierung | Ristorante Busento"
  description="Kontaktieren Sie das Ristorante Busento für Reservierungen, Events oder allgemeine Anfragen. Reservierungen nehmen wir telefonisch entgegen."
>
  <!-- Hero -->
  <section class="relative h-[40vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        alt="Weinglas im eleganten Licht"
        width={1920}
        height={800}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-bg/70"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-text">Kontakt & Reservierung</h1>
      <div class="w-16 h-px bg-gold mx-auto mt-4"></div>
    </div>
  </section>

  <!-- Contact Content -->
  <Section>
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Left Column: Reservation Info -->
        <div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-text mb-6">
            Tischreservierungen
          </h2>
          <div class="bg-bg-light border border-border p-8 mb-8">
            <p class="text-text-muted leading-relaxed mb-6">
              Um Ihnen den besten Service zu bieten, nehmen wir Reservierungen ausschließlich telefonisch entgegen.
              So können wir direkt auf Ihre Wünsche eingehen und Ihnen den perfekten Tisch garantieren.
            </p>
            <a
              href="tel:023692057502"
              class="inline-flex items-center gap-3 text-2xl md:text-3xl font-serif font-bold text-gold hover:text-gold-light transition-colors"
              aria-label="Jetzt telefonisch reservieren"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              02369 20 575 02
            </a>
          </div>

          <div class="space-y-4 text-text-muted">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold shrink-0 mt-1" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <p class="font-bold text-text">Adresse</p>
                <address class="not-italic">
                  Dülmenerstr 16<br>
                  46286 Dorsten
                </address>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold shrink-0 mt-1" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <p class="font-bold text-text">E-Mail</p>
                <a href="mailto:Busentowulfen@gmail.com" class="hover:text-gold transition-colors">
                  Busentowulfen@gmail.com
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-text mb-6">
            Allgemeine Anfragen
          </h2>
          <p class="text-text-muted mb-8">
            Für Events, Feierlichkeiten oder andere Anliegen nutzen Sie gerne unser Kontaktformular.
            Wir melden uns zeitnah bei Ihnen.
          </p>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
          >
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="Neue Anfrage über Busento Website" />
            <input type="hidden" name="from_name" value="Ristorante Busento Website" />

            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
            </div>

            <div>
              <label for="name" class="block text-sm uppercase tracking-widest text-text-muted mb-2">
                Name <span class="text-gold">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                aria-invalid="false"
                class="w-full bg-bg-light border border-border px-4 py-3 text-text placeholder-text-muted/50 focus:border-gold focus:outline-none transition-colors"
                placeholder="Ihr vollständiger Name"
              />
              <p class="text-red-400 text-xs mt-1 hidden" id="name-error">Bitte geben Sie Ihren Namen ein.</p>
            </div>

            <div>
              <label for="email" class="block text-sm uppercase tracking-widest text-text-muted mb-2">
                E-Mail <span class="text-gold">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                aria-invalid="false"
                class="w-full bg-bg-light border border-border px-4 py-3 text-text placeholder-text-muted/50 focus:border-gold focus:outline-none transition-colors"
                placeholder="ihre@email.de"
              />
              <p class="text-red-400 text-xs mt-1 hidden" id="email-error">Bitte geben Sie eine gültige E-Mail-Adresse ein.</p>
            </div>

            <div>
              <label for="message" class="block text-sm uppercase tracking-widest text-text-muted mb-2">
                Nachricht <span class="text-gold">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                aria-invalid="false"
                class="w-full bg-bg-light border border-border px-4 py-3 text-text placeholder-text-muted/50 focus:border-gold focus:outline-none transition-colors resize-y"
                placeholder="Wie können wir Ihnen helfen?"
              ></textarea>
              <p class="text-red-400 text-xs mt-1 hidden" id="message-error">Bitte geben Sie eine Nachricht ein.</p>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="dsgvo"
                name="dsgvo"
                required
                aria-invalid="false"
                class="mt-1 w-4 h-4 border border-border bg-bg-light text-gold focus:ring-gold focus:ring-offset-0"
              />
              <label for="dsgvo" class="text-sm text-text-muted leading-relaxed">
                Ich stimme der Verarbeitung meiner Daten gemäß der
                <a href="/datenschutz" class="text-gold underline hover:text-gold-light">Datenschutzerklärung</a> zu. <span class="text-gold">*</span>
              </label>
            </div>
            <p class="text-red-400 text-xs hidden" id="dsgvo-error">Bitte stimmen Sie der Datenverarbeitung zu.</p>

            <Button type="submit" variant="primary" size="lg" ariaLabel="Nachricht senden" class="w-full">
              Nachricht senden
            </Button>

            <div id="form-status" class="text-center text-sm hidden" role="status" aria-live="polite"></div>
          </form>
        </div>
      </div>
    </Container>
  </Section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusDiv = document.getElementById('form-status');

  function showError(id: string, show: boolean) {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('hidden', !show);

    const fieldId = id.replace('-error', '');
    const field = form?.elements.namedItem(fieldId) as HTMLElement | null;
    if (field) {
      field.setAttribute('aria-invalid', show ? 'true' : 'false');
      if (show) {
        field.setAttribute('aria-describedby', id);
      } else {
        field.removeAttribute('aria-describedby');
      }
    }
  }

  function isValidEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    let valid = true;
    const name = (form.elements.namedItem('name') as HTMLInputElement)?.value.trim();
    const email = (form.elements.namedItem('email') as HTMLInputElement)?.value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement)?.value.trim();
    const dsgvo = (form.elements.namedItem('dsgvo') as HTMLInputElement)?.checked;

    showError('name-error', !name);
    showError('email-error', !email || !isValidEmail(email));
    showError('message-error', !message);
    showError('dsgvo-error', !dsgvo);

    if (!name || !email || !isValidEmail(email) || !message || !dsgvo) {
      valid = false;
    }

    if (!valid) return;

    const formData = new FormData(form);
    if (statusDiv) {
      statusDiv.classList.remove('hidden', 'text-red-400', 'text-green-400');
      statusDiv.classList.add('text-text-muted');
      statusDiv.textContent = 'Wird gesendet...';
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
      });
      const data = await response.json();

      if (data.success) {
        if (statusDiv) {
          statusDiv.classList.remove('hidden', 'text-text-muted', 'text-red-400');
          statusDiv.classList.add('text-green-400');
          statusDiv.textContent = 'Vielen Dank! Ihre Nachricht wurde erfolgreich versendet.';
        }
        form.reset();
      } else {
        throw new Error(data.message || 'Fehler beim Senden');
      }
    } catch (err) {
      if (statusDiv) {
        statusDiv.classList.remove('hidden', 'text-text-muted', 'text-green-400');
        statusDiv.classList.add('text-red-400');
        statusDiv.textContent = 'Es ist ein Fehler aufgetreten. Bitte versuchen Sie es später erneut oder rufen Sie uns an.';
      }
    }
  });
</script>
