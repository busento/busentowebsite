---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';

import heroImage from '../assets/hero.jpg';
import introImage from '../assets/tradition.jpg';
import antipastiImage from '../assets/spaghetti-frutti-di-mare.jpg';
import primiImage from '../assets/taglioline-forma.jpg';
import secondiImage from '../assets/vitello-tonnato.jpg';
---

<Layout
  title="Ristorante Busento – Feine italienische Küche in Dorsten"
  description="Erleben Sie authentische kalabrische Küche im Herzen von Dorsten. Ristorante Busento – Tradition, Leidenschaft und höchste Qualität."
>
  <!-- Hero Section -->
  <section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        alt="Elegantes Ambiente im Ristorante Busento"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-bg/75"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <p class="font-script text-3xl md:text-5xl text-gold-light mb-4">
        Feine italienische Küche. La vera Cucina.
      </p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif font-bold text-text mb-8 tracking-wide">
        Ristorante Busento
      </h1>
      <p class="text-lg md:text-xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Ein Familienbetrieb mit Wurzeln in Kalabrien. Von handgemachter Pasta über knusprige Pizza bis zu edlen Fleisch- und Fischspezialitäten – wir servieren Leidenschaft auf dem Teller.
      </p>
      <Button href="tel:023692057502" variant="primary" size="lg" ariaLabel="Tisch telefonisch reservieren">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Tisch telefonisch reservieren
      </Button>
    </div>
  </section>

  <!-- Intro / Philosophie -->
  <Section>
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative aspect-[4/3] overflow-hidden">
          <Image
            src={introImage}
            alt="Traditionelle italienische Küche im Ristorante Busento"
            width={800}
            height={600}
            class="w-full h-full object-cover"
          />
        </div>
        <div>
          <p class="font-script text-2xl md:text-3xl text-gold mb-2">Tradition & Leidenschaft</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-text mb-6">
            Mehr als nur Essen. Eine Tradition.
          </h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              Im Ristorante Busento dreht sich alles um die echte italienische Küche – weit über Fast-Food hinaus. Neben unserer handgemachten Pasta und klassischen Pizzen stehen handverlesene Zutaten, alte Familienrezepte und die Liebe zum Detail im Mittelpunkt.
              Hier stehen handverlesene Zutaten, alte Familienrezepte und die Liebe zum Detail im Mittelpunkt.
            </p>
            <p>
              Antonio Marte und sein Team empfangen Sie in einem stilvollen Ambiente, in dem jedes Gericht
              eine Geschichte erzählt. Wir sind ein Familienbetrieb, und das spüren Sie – in jedem Bissen.
            </p>
            <p>
              Ob ein romantisches Dinner, ein Geschäftsessen oder ein besonderer Anlass: Bei uns erwartet Sie
              gehobene italienische Küche auf höchstem Niveau.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Menü Teaser -->
  <Section background="light">
    <Container>
      <div class="text-center mb-12">
        <p class="font-script text-2xl md:text-3xl text-gold mb-2">Kulinarische Highlights</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-text">Unsere Speisen</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Taglioline Forma -->
        <div class="group">
          <div class="relative aspect-[4/3] overflow-hidden mb-4">
            <Image
              src={primiImage}
              alt="Taglioline Forma aus dem Parmesanlaib mit Trüffelcreme"
              width={600}
              height={450}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-bg/40 group-hover:bg-bg/20 transition-colors duration-500"></div>
          </div>
          <h3 class="text-xl font-serif font-bold text-text mb-2">Taglioline Forma</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Unser Signature-Dish: Frische Pasta wird direkt im Parmesanlaib geschwenkt und mit edler Trüffelcreme verfeinert. Intensiv, cremig und luxuriös.
          </p>
        </div>

        <!-- Vitello Tonnato -->
        <div class="group">
          <div class="relative aspect-[4/3] overflow-hidden mb-4">
            <Image
              src={secondiImage}
              alt="Vitello Tonnato – ein italienischer Klassiker"
              width={600}
              height={450}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-bg/40 group-hover:bg-bg/20 transition-colors duration-500"></div>
          </div>
          <h3 class="text-xl font-serif font-bold text-text mb-2">Vitello Tonnato</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Ein italienischer Klassiker: Hauchdünnes Kalbfleisch mit cremiger Thunfischsauce und Kapern. Elegant, leicht und zeitlos.
          </p>
        </div>

        <!-- Spaghetti Frutti di Mare -->
        <div class="group">
          <div class="relative aspect-[4/3] overflow-hidden mb-4">
            <Image
              src={antipastiImage}
              alt="Spaghetti Frutti di Mare mit Meeresfrüchten"
              width={600}
              height={450}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-bg/40 group-hover:bg-bg/20 transition-colors duration-500"></div>
          </div>
          <h3 class="text-xl font-serif font-bold text-text mb-2">Spaghetti Frutti di Mare</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Perfekt für Seafood-Fans: Pasta mit Meeresfrüchten, Garnelen, Knoblauch und Tomate – bringt direkt mediterranes Küstenfeeling auf den Teller.
          </p>
        </div>
      </div>

      <div class="text-center mt-10">
        <Button href="/speisekarte" variant="outline" size="md" ariaLabel="Zur vollständigen Speisekarte">
          Zur vollständigen Speisekarte
        </Button>
      </div>
    </Container>
  </Section>

  <!-- Trauer-Café -->
  <Section background="light">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center text-gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0L12 2.69z"/></svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-text mb-2">
          Trauercafé im Restaurant Busento
        </h2>
        <p class="font-script text-2xl md:text-3xl text-gold mb-8">Ein Ort der stillen Einkehr</p>
        <div class="text-text-muted leading-relaxed space-y-4 max-w-2xl mx-auto">
          <p>
            In Zeiten der Trauer ist es uns ein besonderes Anliegen, Ihnen einen stillen und würdevollen
            Rahmen für Ihr Beerdigungskaffeetrinken zu bieten.
          </p>
          <p>
            Im Restaurant Busento finden Sie einen Ort der Ruhe und des Zusammenkommens, wo Sie in aller Stille
            der verstorbenen Person gedenken können. Wir übernehmen die Organisation und Bewirtung,
            damit Sie sich ganz auf Ihre Familie und Freunde konzentrieren können.
          </p>
        </div>
        <div class="mt-8">
          <Button href="tel:023692057502" variant="outline" size="md" ariaLabel="Telefonisch für Trauer-Café anfragen">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Individuell beraten lassen
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Social Proof / Inhaber -->
  <Section>
    <Container size="large">
      <div class="relative bg-bg-light border border-border p-8 md:p-16 text-center max-w-5xl mx-auto">
        <div class="mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-gold/30 mx-auto" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
        </div>
        <blockquote>
          <p class="font-script text-2xl md:text-4xl text-gold-light leading-relaxed mb-6">
            "Für mich ist Kochen keine Arbeit – es ist die schönste Art, meine Heimat zu teilen.
            Jeder Teller, der unsere Küche verlässt, trägt ein Stück Kalabrien in sich."
          </p>
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-12 h-px bg-gold"></div>
          <p class="text-sm uppercase tracking-widest text-text-muted">Antonio Marte, Inhaber</p>
          <div class="w-12 h-px bg-gold"></div>
        </div>
      </div>
    </Container>
  </Section>
</Layout>
